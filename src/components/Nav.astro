---
const navItems = [
  { name: "Projects", path: "/blog" },
  { name: "Resume", path: "/resume" },
  { name: "Contact", path: "/contact" },
];
---

<nav
  class="flex flex-row items-start relative px-0 pb-0 fade md:relative mb-16"
>
  <div class="flex items-center justify-between w-full">
    <a href="/" class="py-1 relative text-3xl">🏠</a>
    <div class="flex flex-row space-x-6">
      {
        navItems.map((item) => (
          <a
            href={item.path}
            class="transition-all flex align-middle relative py-1 font-semibold hover:text-emerald-500"
          >
            {item.name}
          </a>
        ))
      }
    </div>
  </div>
</nav>
